# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez


# Temporary files, for example, from tests.
/tmp/

# =============================================================================
# Environment & Secrets
# =============================================================================

# Environment variables
.env
.env.local
.env.*.local

# Secrets
/config/*.secret.exs
/config/prod.secret.exs

# =============================================================================
# IDEs & Editors
# =============================================================================

# VS Code
.vscode/
*.code-workspace

# IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws

# Emacs
*~
\#*\#
.\#*
.dir-locals.el

# Vim
*.swp
*.swo
*.swn
.netrwhist

# Sublime Text
*.sublime-project
*.sublime-workspace

# =============================================================================
# OS Files
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# =============================================================================
# Elixir / Erlang
# =============================================================================

# Dialyzer
/priv/plts/*.plt
/priv/plts/*.plt.hash
.dialyzer_ignore.exs

# Elixir LS
/.elixir_ls/

# =============================================================================
# Testing & Coverage
# =============================================================================

# ExCoveralls
/cover/
coveralls.json

# Test artifacts
test/support/tmp/
test/tmp/

# =============================================================================
# Documentation
# =============================================================================

# Generated docs
/doc/
docs/

# =============================================================================
# CI/CD
# =============================================================================

# CircleCI
.circleci/local/

# GitHub Actions
.github/workflows/local/

# =============================================================================
# Deployment
# =============================================================================

# Releases
/rel/
/_build/prod/

# =============================================================================
# Logs
# =============================================================================

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# Database
# =============================================================================

# SQLite
*.db
*.sqlite
*.sqlite3

# =============================================================================
# Node (if using for assets)
# =============================================================================

node_modules/
npm-debug.log
package-lock.json
yarn.lock

# =============================================================================
# Misc
# =============================================================================

# Backup files
*.bak
*.backup

# Benchmarks
/benchmarks/results/

# Cache
.cache/

# Hex
hex_metadata.config
